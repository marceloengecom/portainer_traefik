# Email usado para o Let's Encrypt (certificados SSL)
LETSENCRYPT_EMAIL=email@dominio.com

# Nome da rede Docker Swarm compartilhada com os serviços
DOCKER_NETWORK=Rede_Docker

TRAEFIK_DOMAIN=traefik.dominio.com

PORTAINER_DOMAIN=portainer.dominio.com

# Usuário e Senha administrativa do traefik, em formato hash.
# Para gerar, use o seguinte comando: echo $(htpasswd -nb admin SUASENHA) | sed -e s/\\$/\\$\\$/g
# Pegue a linha completo: ex: admin:$$apr1$$lBsuttJy$$a2N91zCtXdH6fEAXHM6HY
HASH_TRAEFIK=UsuarioSenhaHashTraefik

